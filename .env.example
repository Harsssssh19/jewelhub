# JewelHub environment variables
# Copy this file to `.env` and replace the placeholder values.

# Core Django
SECRET_KEY=replace-with-a-strong-secret-key
DEBUG=False
USE_SERVERLESS=True
SECURE_SSL_REDIRECT=False

# Database - Supabase/Postgres
# Preferred: use a single DATABASE_URL value from Supabase.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase client/public values
# Safe to use in browser-side code if you add Supabase client features.
SUPABASE_URL=https://xyzcompany.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Email / SMTP for contact form notifications
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=30
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your-smtp-app-password
DEFAULT_FROM_EMAIL=you@example.com
CONTACT_RECEIVER_EMAIL=admin@example.com
